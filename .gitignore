# Rust
/.target/
**/.target/
**/*.rs.bk
Cargo.lock.bak

# IDE
.vscode/
.idea/
*.iml

# Editor backup
*~
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Tooling caches
.cargo-cache/
sccache/

# Local-only runtime artefacts (per-developer test DBs, sample exports).
# `ee/tests/fixtures/` and `ee/Dict/data/` are intentionally tracked.
*.sqlite3-shm
*.sqlite3-wal
/notes.local.json

# ECDICT source database (build input for ee/Core/src/bin/generator.rs).
# Large (~800MB) upstream import; not committed — download from the ECDICT
# release and place at ee/Dict/ecdict.db to regenerate word_en_v1(.sqlite).
/ee/Dict/ecdict.db
/ee/Dict/kaikki.org-dictionary-English.jsonl.gz

# Legacy Windows system fonts copied by old local scripts; do not commit.
/ee/App/Assets/segoeui.ttf
/ee/App/Assets/msyh.ttc

# Generated Windows installer artifacts (built by ee/App/Win/win_package.bat).
/ee/Release/
